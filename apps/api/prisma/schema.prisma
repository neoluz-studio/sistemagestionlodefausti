generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  CAJA
}

enum PaymentMethod {
  CASH
  TRANSFER
  DEBIT
  CREDIT
  QR
  OTHER
}

enum SaleStatus {
  DRAFT
  COMPLETED
  CANCELED
  REFUNDED
}

enum InventoryMovementType {
  IN
  OUT
  ADJUSTMENT
  RETURN
  SALE_OUTPUT
  SALE_CANCEL_RETURN
}

enum CashSessionStatus {
  OPEN
  CLOSED
}

enum CashMovementType {
  OPENING
  INCOME
  EXPENSE
  WITHDRAWAL
  CLOSING
}

enum WhatsappCampaignStatus {
  DRAFT
  SCHEDULED
  RUNNING
  PAUSED
  COMPLETED
  CANCELED
}

enum WhatsappMessageStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
}

model Tenant {
  id          String              @id @default(uuid()) @db.Uuid
  name        String              @db.VarChar(150)
  slug        String              @unique @db.VarChar(150)
  isActive    Boolean             @default(true) @map("is_active")
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")
  stores      Store[]
  users       User[]
  categories  Category[]
  products    Product[]
  inventoryMovements InventoryMovement[]
  stockAlerts StockAlert[]
  customers   Customer[]
  cashSessions CashSession[]
  cashMovements CashMovement[]
  sales       Sale[]
  templates   WhatsappTemplate[]
  campaigns   WhatsappCampaign[]
  messages    WhatsappMessage[]
  files       File[]
  auditLogs   AuditLog[]

  @@map("tenants")
}

model Store {
  id                 String               @id @default(uuid()) @db.Uuid
  tenantId           String               @map("tenant_id") @db.Uuid
  name               String               @db.VarChar(150)
  code               String               @db.VarChar(30)
  address            String?              @db.VarChar(255)
  phone              String?              @db.VarChar(50)
  isActive           Boolean              @default(true) @map("is_active")
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")
  tenant             Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users              User[]
  categories         Category[]
  products           Product[]
  inventoryMovements InventoryMovement[]
  stockAlerts        StockAlert[]
  customers          Customer[]
  cashSessions       CashSession[]
  cashMovements      CashMovement[]
  sales              Sale[]
  templates          WhatsappTemplate[]
  campaigns          WhatsappCampaign[]
  messages           WhatsappMessage[]
  files              File[]
  auditLogs          AuditLog[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("stores")
}

model User {
  id             String         @id @default(uuid()) @db.Uuid
  tenantId       String         @map("tenant_id") @db.Uuid
  storeId        String?        @map("store_id") @db.Uuid
  email          String         @db.VarChar(180)
  username       String?        @db.VarChar(80)
  passwordHash   String         @map("password_hash") @db.VarChar(255)
  fullName       String         @map("full_name") @db.VarChar(180)
  role           UserRole
  isActive       Boolean        @default(true) @map("is_active")
  lastLoginAt    DateTime?      @map("last_login_at")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  store          Store?         @relation(fields: [storeId], references: [id], onDelete: SetNull)
  refreshTokens  RefreshToken[]
  auditLogs      AuditLog[]
  cashSessions   CashSession[]
  cashMovements  CashMovement[]
  inventoryMovements InventoryMovement[]
  sales          Sale[]
  templates      WhatsappTemplate[]
  campaigns      WhatsappCampaign[]
  files          File[]

  @@unique([tenantId, email])
  @@unique([tenantId, username])
  @@index([tenantId, role])
  @@map("users")
}

model RefreshToken {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  tokenHash  String   @map("token_hash") @db.VarChar(255)
  expiresAt  DateTime @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime @default(now()) @map("created_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  storeId    String?  @map("store_id") @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  action     String   @db.VarChar(100)
  entity     String   @db.VarChar(100)
  entityId   String?  @map("entity_id") @db.VarChar(100)
  metadata   Json?
  ipAddress  String?  @map("ip_address") @db.VarChar(64)
  userAgent  String?  @map("user_agent") @db.VarChar(255)
  createdAt  DateTime @default(now()) @map("created_at")
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  store      Store?   @relation(fields: [storeId], references: [id], onDelete: SetNull)
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([storeId])
  @@index([userId])
  @@map("audit_logs")
}

model Category {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  storeId     String    @map("store_id") @db.Uuid
  name        String    @db.VarChar(120)
  description String?   @db.VarChar(255)
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  store       Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  products    Product[]

  @@unique([storeId, name])
  @@index([tenantId, storeId])
  @@map("categories")
}

model Product {
  id                 String               @id @default(uuid()) @db.Uuid
  tenantId           String               @map("tenant_id") @db.Uuid
  storeId            String               @map("store_id") @db.Uuid
  categoryId         String?              @map("category_id") @db.Uuid
  sku                String               @db.VarChar(80)
  name               String               @db.VarChar(180)
  description        String?              @db.VarChar(500)
  unit               String               @default("unit") @db.VarChar(20)
  costPrice          Decimal              @default(0) @map("cost_price") @db.Decimal(12, 2)
  salePrice          Decimal              @default(0) @map("sale_price") @db.Decimal(12, 2)
  stock              Decimal              @default(0) @db.Decimal(12, 3)
  minStock           Decimal              @default(0) @map("min_stock") @db.Decimal(12, 3)
  isActive           Boolean              @default(true) @map("is_active")
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")
  tenant             Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  store              Store                @relation(fields: [storeId], references: [id], onDelete: Cascade)
  category           Category?            @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  inventoryMovements InventoryMovement[]
  stockAlerts        StockAlert[]
  saleItems          SaleItem[]

  @@unique([storeId, sku])
  @@index([tenantId, storeId, name])
  @@map("products")
}

model InventoryMovement {
  id            String                @id @default(uuid()) @db.Uuid
  tenantId      String                @map("tenant_id") @db.Uuid
  storeId       String                @map("store_id") @db.Uuid
  productId     String                @map("product_id") @db.Uuid
  userId        String?               @map("user_id") @db.Uuid
  type          InventoryMovementType
  quantity      Decimal               @db.Decimal(12, 3)
  previousStock Decimal               @map("previous_stock") @db.Decimal(12, 3)
  currentStock  Decimal               @map("current_stock") @db.Decimal(12, 3)
  reason        String?               @db.VarChar(255)
  createdAt     DateTime              @default(now()) @map("created_at")
  tenant        Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  store         Store                 @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product       Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  user          User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, storeId, productId, createdAt])
  @@map("inventory_movements")
}

model StockAlert {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  storeId    String   @map("store_id") @db.Uuid
  productId  String   @map("product_id") @db.Uuid
  threshold  Decimal  @db.Decimal(12, 3)
  isResolved Boolean  @default(false) @map("is_resolved")
  resolvedAt DateTime? @map("resolved_at")
  createdAt  DateTime @default(now()) @map("created_at")
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  store      Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([tenantId, storeId, isResolved])
  @@map("stock_alerts")
}

model Customer {
  id          String            @id @default(uuid()) @db.Uuid
  tenantId    String            @map("tenant_id") @db.Uuid
  storeId     String            @map("store_id") @db.Uuid
  fullName    String            @map("full_name") @db.VarChar(180)
  phone       String?           @db.VarChar(30)
  email       String?           @db.VarChar(180)
  notes       String?           @db.VarChar(255)
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  store       Store             @relation(fields: [storeId], references: [id], onDelete: Cascade)
  sales       Sale[]
  messages    WhatsappMessage[]

  @@index([tenantId, storeId, fullName])
  @@map("customers")
}

model CashSession {
  id             String            @id @default(uuid()) @db.Uuid
  tenantId       String            @map("tenant_id") @db.Uuid
  storeId        String            @map("store_id") @db.Uuid
  userId         String            @map("user_id") @db.Uuid
  status         CashSessionStatus @default(OPEN)
  openedAt       DateTime          @default(now()) @map("opened_at")
  closedAt       DateTime?         @map("closed_at")
  openingAmount  Decimal           @map("opening_amount") @db.Decimal(12, 2)
  closingAmount  Decimal?          @map("closing_amount") @db.Decimal(12, 2)
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")
  tenant         Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  store          Store             @relation(fields: [storeId], references: [id], onDelete: Cascade)
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  movements      CashMovement[]
  sales          Sale[]

  @@index([tenantId, storeId, status])
  @@map("cash_sessions")
}

model CashMovement {
  id            String           @id @default(uuid()) @db.Uuid
  tenantId      String           @map("tenant_id") @db.Uuid
  storeId       String           @map("store_id") @db.Uuid
  cashSessionId String           @map("cash_session_id") @db.Uuid
  userId        String           @map("user_id") @db.Uuid
  type          CashMovementType
  amount        Decimal          @db.Decimal(12, 2)
  description   String?          @db.VarChar(255)
  createdAt     DateTime         @default(now()) @map("created_at")
  tenant        Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  store         Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  cashSession   CashSession      @relation(fields: [cashSessionId], references: [id], onDelete: Cascade)
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, storeId, cashSessionId, createdAt])
  @@map("cash_movements")
}

model Sale {
  id            String        @id @default(uuid()) @db.Uuid
  tenantId      String        @map("tenant_id") @db.Uuid
  storeId       String        @map("store_id") @db.Uuid
  saleNumber    Int           @map("sale_number")
  customerId    String?       @map("customer_id") @db.Uuid
  userId        String        @map("user_id") @db.Uuid
  cashSessionId String?       @map("cash_session_id") @db.Uuid
  status        SaleStatus    @default(DRAFT)
  subtotal      Decimal       @db.Decimal(12, 2)
  discount      Decimal       @default(0) @db.Decimal(12, 2)
  tax           Decimal       @default(0) @db.Decimal(12, 2)
  total         Decimal       @db.Decimal(12, 2)
  notes         String?       @db.VarChar(255)
  soldAt        DateTime      @default(now()) @map("sold_at")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  store         Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer      Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  cashSession   CashSession?  @relation(fields: [cashSessionId], references: [id], onDelete: SetNull)
  items         SaleItem[]
  payments      SalePayment[]

  @@index([tenantId, storeId, soldAt])
  @@unique([storeId, saleNumber])
  @@index([customerId])
  @@map("sales")
}

model SaleItem {
  id         String   @id @default(uuid()) @db.Uuid
  saleId     String   @map("sale_id") @db.Uuid
  productId  String   @map("product_id") @db.Uuid
  quantity   Decimal  @db.Decimal(12, 3)
  unitPrice  Decimal  @map("unit_price") @db.Decimal(12, 2)
  subtotal   Decimal  @db.Decimal(12, 2)
  createdAt  DateTime @default(now()) @map("created_at")
  sale       Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([saleId])
  @@index([productId])
  @@map("sale_items")
}

model SalePayment {
  id            String        @id @default(uuid()) @db.Uuid
  saleId         String        @map("sale_id") @db.Uuid
  method         PaymentMethod
  amount         Decimal       @db.Decimal(12, 2)
  reference      String?       @db.VarChar(120)
  paidAt         DateTime      @default(now()) @map("paid_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  sale           Sale          @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
  @@map("sale_payments")
}

model WhatsappTemplate {
  id          String             @id @default(uuid()) @db.Uuid
  tenantId    String             @map("tenant_id") @db.Uuid
  storeId     String             @map("store_id") @db.Uuid
  createdById String?            @map("created_by_id") @db.Uuid
  name        String             @db.VarChar(120)
  content     String             @db.VarChar(3000)
  isActive    Boolean            @default(true) @map("is_active")
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")
  tenant      Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  store       Store              @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdBy   User?              @relation(fields: [createdById], references: [id], onDelete: SetNull)
  campaigns   WhatsappCampaign[]

  @@unique([storeId, name])
  @@index([tenantId, storeId, isActive])
  @@map("whatsapp_templates")
}

model WhatsappCampaign {
  id            String                 @id @default(uuid()) @db.Uuid
  tenantId      String                 @map("tenant_id") @db.Uuid
  storeId       String                 @map("store_id") @db.Uuid
  templateId    String?                @map("template_id") @db.Uuid
  createdById   String?                @map("created_by_id") @db.Uuid
  name          String                 @db.VarChar(150)
  status        WhatsappCampaignStatus @default(DRAFT)
  scheduledAt   DateTime?              @map("scheduled_at")
  sentAt        DateTime?              @map("sent_at")
  createdAt     DateTime               @default(now()) @map("created_at")
  updatedAt     DateTime               @updatedAt @map("updated_at")
  tenant        Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  store         Store                  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  template      WhatsappTemplate?      @relation(fields: [templateId], references: [id], onDelete: SetNull)
  createdBy     User?                  @relation(fields: [createdById], references: [id], onDelete: SetNull)
  messages      WhatsappMessage[]

  @@index([tenantId, storeId, status])
  @@map("whatsapp_campaigns")
}

model WhatsappMessage {
  id             String                @id @default(uuid()) @db.Uuid
  tenantId       String                @map("tenant_id") @db.Uuid
  storeId        String                @map("store_id") @db.Uuid
  campaignId     String?               @map("campaign_id") @db.Uuid
  customerId     String?               @map("customer_id") @db.Uuid
  phone          String                @db.VarChar(30)
  content        String                @db.VarChar(3000)
  status         WhatsappMessageStatus @default(QUEUED)
  providerMsgId  String?               @map("provider_msg_id") @db.VarChar(120)
  sentAt         DateTime?             @map("sent_at")
  deliveredAt    DateTime?             @map("delivered_at")
  readAt         DateTime?             @map("read_at")
  failedReason   String?               @map("failed_reason") @db.VarChar(255)
  createdAt      DateTime              @default(now()) @map("created_at")
  tenant         Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  store          Store                 @relation(fields: [storeId], references: [id], onDelete: Cascade)
  campaign       WhatsappCampaign?     @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  customer       Customer?             @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([tenantId, storeId, status, createdAt])
  @@map("whatsapp_messages")
}

model File {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  storeId      String?  @map("store_id") @db.Uuid
  uploadedById String?  @map("uploaded_by_id") @db.Uuid
  fileName     String   @map("file_name") @db.VarChar(255)
  mimeType     String   @map("mime_type") @db.VarChar(120)
  sizeBytes    Int      @map("size_bytes")
  path         String   @db.VarChar(500)
  createdAt    DateTime @default(now()) @map("created_at")
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  store        Store?   @relation(fields: [storeId], references: [id], onDelete: SetNull)
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([tenantId, storeId])
  @@map("files")
}
